# ── Groq API Integration ──────────────────────────────────────────────────────
# Get your API key from: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# How to pass this to your Spring Boot application locally:
# 
# Option 1: IntelliJ IDEA (Recommended)
# Run -> Edit Configurations -> Select your Spring Boot App
# Add to Environment Variables box: GROQ_API_KEY=your_groq_api_key_here
#
# Option 2: Maven Wrapper / Terminal
# export GROQ_API_KEY=your_groq_api_key_here
# ./mvnw spring-boot:run
# 
# Option 3: Command Line VM Option
# -Dgroq.api-key=your_groq_api_key_here
